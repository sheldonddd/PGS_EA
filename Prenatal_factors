bind_without_duplicate_columns <- function(df_left, df_right) {
  duplicated_cols <- intersect(colnames(df_left), colnames(df_right))
  df_right_unique <- df_right[, setdiff(colnames(df_right), duplicated_cols), drop = FALSE]
  cbind(df_left, df_right_unique)
}

