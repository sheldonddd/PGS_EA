# ============================================================
# 4. Helper functions
# ============================================================

to_numeric_safely <- function(x) {
  if (is.numeric(x)) return(x)
  suppressWarnings(as.numeric(x))
}

standardize_column <- function(x) {
  as.numeric(scale(x))
}

format_sex_variable <- function(dat, sex_col = "sex") {
  if (!sex_col %in% names(dat)) {
    stop("Missing sex column: ", sex_col)
  }
  dat[[sex_col]] <- as.factor(dat[[sex_col]])
  if (all(c("Female", "Male") %in% levels(dat[[sex_col]]))) {
    dat[[sex_col]] <- factor(dat[[sex_col]], levels = c("Female", "Male"))
  }
  dat
}

keep_only_unexposed <- function(x) {
  if (is.numeric(x)) return(!is.na(x) & x == 0)
  if (is.logical(x)) return(!is.na(x) & x == FALSE)
  xx <- trimws(as.character(x))
  suppressWarnings(nx <- as.numeric(xx))
  !is.na(nx) & nx == 0
}

convert_to_binary_strict <- function(x) {
  if (is.numeric(x)) return(ifelse(x %in% c(0, 1), x, NA_real_))
  if (is.logical(x)) return(ifelse(is.na(x), NA_real_, ifelse(x, 1, 0)))
  xx <- trimws(as.character(x))
  suppressWarnings(nx <- as.numeric(xx))
  ifelse(nx %in% c(0, 1), nx, NA_real_)
}

get_trio_prs_terms <- function(prs) {
  c(prs, paste0("fa_", prs), paste0("mo_", prs))
}

add_trio_role <- function(df) {
  df %>%
    mutate(
      role = case_when(
        grepl("^fa_", variable) ~ "Paternal",
        grepl("^mo_", variable) ~ "Maternal",
        TRUE ~ "Proband"
      ),
      prs_base = gsub("^fa_|^mo_", "", variable)
    )
}

# ============================================================
# 5. Fixed-effect meta-analysis functions
# ============================================================

meta_two_studies_linear <- function(res_D, res_R,
                                    key_cols,
                                    beta_col = "Estimate",
                                    se_col = "Std. Error") {
  D <- res_D %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, R2) %>%
    rename(beta_D = all_of(beta_col), se_D = all_of(se_col), n_D = n, R2_D = R2)

  R <- res_R %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, R2) %>%
    rename(beta_R = all_of(beta_col), se_R = all_of(se_col), n_R = n, R2_R = R2)

  M <- inner_join(D, R, by = key_cols) %>%
    filter(
      is.finite(beta_D), is.finite(beta_R),
      is.finite(se_D), is.finite(se_R),
      se_D > 0, se_R > 0
    )

  if (nrow(M) == 0) return(M)

  wD <- 1 / (M$se_D^2)
  wR <- 1 / (M$se_R^2)
  w  <- wD + wR

  beta_FE <- (wD * M$beta_D + wR * M$beta_R) / w
  se_FE   <- sqrt(1 / w)
  z_FE    <- beta_FE / se_FE
  p_FE    <- 2 * pnorm(-abs(z_FE))

  M %>%
    mutate(
      beta_FE = beta_FE,
      se_FE = se_FE,
      z_FE = z_FE,
      p_FE = p_FE
    )
}

meta_two_studies_logistic <- function(res_D, res_R,
                                      key_cols,
                                      beta_col = "Estimate",
                                      se_col = "Std. Error") {
  M <- meta_two_studies_linear(res_D, res_R, key_cols, beta_col, se_col)
  if (nrow(M) == 0) return(M)

  M %>%
    mutate(
      OR_FE = exp(beta_FE),
      CI_lower_FE = exp(beta_FE - 1.96 * se_FE),
      CI_upper_FE = exp(beta_FE + 1.96 * se_FE)
    )
}

# ============================================================
# 6. Logistic models: prenatal factors as outcomes
# ============================================================

run_univariate_prs_logistic <- function(data, Y_list, X_interest,
                                        age_col = "med_age",
                                        pc_cols = paste0("X", 1:10)) {
  dat <- as.data.table(data)
  dat <- format_sex_variable(dat)

  numeric_cols <- unique(c(Y_list, X_interest, age_col, pc_cols))
  for (v in intersect(numeric_cols, names(dat))) {
    if (v != "sex") dat[[v]] <- to_numeric_safely(dat[[v]])
  }

  for (x in X_interest) {
    if (x %in% names(dat) && is.numeric(dat[[x]])) {
      dat[[paste0(x, "_z")]] <- standardize_column(dat[[x]])
    }
  }

  for (pc in pc_cols) {
    if (pc %in% names(dat) && is.numeric(dat[[pc]])) {
      dat[[paste0(pc, "_z")]] <- standardize_column(dat[[pc]])
    }
  }

  out <- list()

  for (y in Y_list) {
    if (!y %in% names(dat)) next
    dat[[y]] <- as.numeric(dat[[y]])

    for (x in X_interest) {
      x_z <- paste0(x, "_z")
      if (!x_z %in% names(dat)) next

      model_terms <- c(
        x_z,
        "sex",
        age_col,
        intersect(paste0(pc_cols, "_z"), names(dat))
      )

      model_formula <- as.formula(paste0(y, " ~ ", paste(model_terms, collapse = " + ")))
      fit <- glm(model_formula, data = dat, family = binomial)
      sm  <- summary(fit)

      coef_tab <- as.data.frame(sm$coefficients)
      if (!x_z %in% rownames(coef_tab)) next

      row <- coef_tab[x_z, , drop = FALSE]
      row$OR       <- exp(row$Estimate)
      row$CI_lower <- exp(row$Estimate - 1.96 * row$`Std. Error`)
      row$CI_upper <- exp(row$Estimate + 1.96 * row$`Std. Error`)
      row$n        <- nobs(fit)

      null_fit <- glm(as.formula(paste0(y, " ~ 1")), data = dat, family = binomial)
      row$R2 <- 1 - as.numeric(logLik(fit) / logLik(null_fit))

      row$variable  <- x
      row$phenotype <- y
      out[[paste(y, x, sep = "_")]] <- row
    }
  }

  res <- do.call(rbind, out)
  rownames(res) <- NULL
  res
}

trio_prs_variables <- unique(unlist(lapply(prs_set, get_trio_prs_terms)))

res_prenatal_D <- run_univariate_prs_logistic(
  info_D_phe_asd,
  prenatal_factors,
  trio_prs_variables
)

res_prenatal_R <- run_univariate_prs_logistic(
  info_R_phe_asd,
  prenatal_factors,
  trio_prs_variables
)

meta_prenatal_FE <- meta_two_studies_logistic(
  res_prenatal_D,
  res_prenatal_R,
  key_cols = c("phenotype", "variable")
) %>%
  add_trio_role()

write.xlsx(
