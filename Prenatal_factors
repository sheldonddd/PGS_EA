# ============================================================
# 7. Linear trio model for quantitative phenotypes
# ============================================================

run_multivariate_trio_linear <- function(data, Y_list, X_interest,
                                         prenatal_covariate = NULL,
                                         pc_cols = paste0("X", 1:10)) {
  dat <- as.data.table(data)
  dat <- format_sex_variable(dat)

  if (!is.null(prenatal_covariate)) {
    if (!prenatal_covariate %in% names(dat)) {
      warning("Prenatal covariate not found and will be ignored: ", prenatal_covariate)
      prenatal_covariate <- NULL
    } else {
      dat[[prenatal_covariate]] <- convert_to_binary_strict(dat[[prenatal_covariate]])
    }
  }

  numeric_cols <- unique(c(
    Y_list,
    paste0(Y_list, "_age"),
    X_interest,
    pc_cols,
    prenatal_covariate
  ))

  for (v in intersect(numeric_cols, names(dat))) {
    if (v != "sex") dat[[v]] <- to_numeric_safely(dat[[v]])
  }

  for (pc in pc_cols) {
    if (pc %in% names(dat) && is.numeric(dat[[pc]])) {
      dat[[paste0(pc, "_z")]] <- standardize_column(dat[[pc]])
    }
  }

  X_interest_z <- character(0)
  for (x in X_interest) {
    if (!x %in% names(dat)) {
      warning("Variable not found and skipped: ", x)
      next
    }
    if (is.numeric(dat[[x]])) {
      x_z <- paste0(x, "_z")
      dat[[x_z]] <- standardize_column(dat[[x]])
      X_interest_z <- c(X_interest_z, x_z)
    } else {
      warning("Non-numeric variable skipped: ", x)
    }
  }

  if (length(X_interest_z) == 0) {
    stop("No valid numeric predictors found in X_interest.")
  }

  out <- list()

  for (y in Y_list) {
    if (!y %in% names(dat)) next
    if (!is.numeric(dat[[y]])) next

    y_z <- paste0(y, "_z")
    dat[[y_z]] <- standardize_column(dat[[y]])
    age_var <- paste0(y, "_age")

    model_terms <- c(
      X_interest_z,
      "sex",
      prenatal_covariate,
      if (age_var %in% names(dat)) age_var else NULL,
      intersect(paste0(pc_cols, "_z"), names(dat))
    )

    model_formula <- as.formula(paste0(y_z, " ~ ", paste(model_terms, collapse = " + ")))
    fit <- lm(model_formula, data = dat)
    sm  <- summary(fit)

    coef_tab <- as.data.frame(sm$coefficients)
    coef_tab$variable <- rownames(coef_tab)

    selected <- coef_tab[coef_tab$variable %in% X_interest_z, , drop = FALSE]
    if (nrow(selected) == 0) next

    selected$variable  <- sub("_z$", "", selected$variable)
    selected$phenotype <- y
    selected$R2        <- sm$r.squared
    selected$n         <- nobs(fit)

    out[[y]] <- selected
  }

  res <- do.call(rbind, out)
  rownames(res) <- NULL
  res
}

run_trio_linear_all_prs <- function(data, prs_set, Y_list,
                                    prenatal_covariate = NULL) {
  all_results <- lapply(prs_set, function(prs) {
    X_interest <- get_trio_prs_terms(prs)
    tmp <- run_multivariate_trio_linear(
      data,
      Y_list,
      X_interest,
      prenatal_covariate = prenatal_covariate
    )
    tmp$PRS <- prs
    tmp
  })
  do.call(rbind, all_results)
}

