# ============================================================
# 9. Compare sensitivity results against baseline
# ============================================================

compare_to_baseline <- function(meta_all,
                                baseline_strategy = "baseline",
                                compare_strategies = c("exclude_exposed", "adjust_prenatal_covariate"),
                                alpha = 0.05,
                                id_cols = c("phenotype", "PRS", "variable")) {
  baseline <- meta_all %>%
    filter(prenatal_factor == "none", strategy == baseline_strategy) %>%
    select(all_of(id_cols), beta0 = beta_FE, se0 = se_FE, p0 = p_FE)

  comparison <- meta_all %>%
    filter(prenatal_factor != "none", strategy %in% compare_strategies) %>%
    select(prenatal_factor, strategy, all_of(id_cols),
           beta1 = beta_FE, se1 = se_FE, p1 = p_FE,
           n_D, n_R)

  comparison %>%
    left_join(baseline, by = id_cols) %>%
    mutate(
      delta_beta = beta1 - beta0,
      se_diff = sqrt(se1^2 + se0^2),
      z_diff = delta_beta / se_diff,
      p_diff = 2 * pnorm(-abs(z_diff)),
      significant_baseline = p0 < alpha,
      significant_sensitivity = p1 < alpha,
      direction_flip = sign(beta1) != sign(beta0),
      significance_flip = significant_baseline != significant_sensitivity,
      cross_zero = beta0 * beta1 < 0,
      abs_delta_beta = abs(delta_beta),
      relative_change = abs_delta_beta / (abs(beta0) + 1e-12)
    ) %>%
    arrange(desc(abs_delta_beta))
}

meta_shift <- compare_to_baseline(meta_linear_all)

