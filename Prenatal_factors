# ============================================================
# 10. Interaction models: prenatal factor × trio PGS
# ============================================================

run_trio_interaction_models <- function(data, Y_list, prs_set, prenatal_factor,
                                        pc_cols = paste0("X", 1:10)) {
  dat <- as.data.table(data)
  dat <- format_sex_variable(dat)

  if (!prenatal_factor %in% names(dat)) {
    stop("Prenatal factor not found: ", prenatal_factor)
  }

  dat$prenatal_binary <- convert_to_binary_strict(dat[[prenatal_factor]])

  for (pc in pc_cols) {
    if (pc %in% names(dat)) {
      dat[[pc]] <- to_numeric_safely(dat[[pc]])
      if (is.numeric(dat[[pc]])) {
        dat[[paste0(pc, "_z")]] <- standardize_column(dat[[pc]])
      }
    }
  }

  pc_z <- intersect(paste0(pc_cols, "_z"), names(dat))
  out <- list()

  for (prs in prs_set) {
    prs_terms <- get_trio_prs_terms(prs)

    if (!all(prs_terms %in% names(dat))) {
      warning("Missing trio PGS columns for: ", prs)
      next
    }

    for (v in prs_terms) {
      dat[[v]] <- to_numeric_safely(dat[[v]])
      if (is.numeric(dat[[v]])) {
        dat[[paste0(v, "_z")]] <- standardize_column(dat[[v]])
      }
    }

    prs_z <- paste0(prs_terms, "_z")
    interaction_terms <- paste0(prs_z, ":prenatal_binary")

    for (y in Y_list) {
      if (!y %in% names(dat)) next
      dat[[y]] <- to_numeric_safely(dat[[y]])
      if (!is.numeric(dat[[y]])) next

      y_z <- paste0(y, "_z")
      dat[[y_z]] <- standardize_column(dat[[y]])

      age_var <- paste0(y, "_age")
      if (age_var %in% names(dat)) {
        dat[[age_var]] <- to_numeric_safely(dat[[age_var]])
      }

      model_terms <- c(
        prs_z,
        "prenatal_binary",
        interaction_terms,
        "sex",
        if (age_var %in% names(dat)) age_var else NULL,
        pc_z
      )

      model_formula <- as.formula(paste0(y_z, " ~ ", paste(model_terms, collapse = " + ")))
      fit <- lm(model_formula, data = dat)
      sm  <- summary(fit)

      coef_tab <- as.data.frame(sm$coefficients)
      coef_tab$term <- rownames(coef_tab)

      selected <- coef_tab[coef_tab$term %in% interaction_terms, , drop = FALSE]
      if (nrow(selected) == 0) next

      selected$phenotype <- y
      selected$PRS <- prs
      selected$prenatal_factor <- prenatal_factor
      selected$n <- nobs(fit)
      selected$R2 <- sm$r.squared
      selected$role <- case_when(
        selected$term == interaction_terms[1] ~ "Proband",
        selected$term == interaction_terms[2] ~ "Paternal",
        selected$term == interaction_terms[3] ~ "Maternal",
        TRUE ~ NA_character_
      )

      out[[paste(prs, y, prenatal_factor, sep = "|")]] <- selected
    }
  }

  res <- do.call(rbind, out)
  rownames(res) <- NULL
  res
}

res_interaction_D <- do.call(rbind, lapply(
  prenatal_factors,
  function(pf) run_trio_interaction_models(
