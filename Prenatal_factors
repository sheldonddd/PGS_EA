# ============================================================
# 11. Plotting functions
# ============================================================

plot_prenatal_factor_forest <- function(meta_data,
                                        target_phenotype = "med_cond_birth",
                                        prs_order = c("EA", "CP", "NON_COG")) {
  plot_data <- meta_data %>%
    filter(phenotype == target_phenotype) %>%
    mutate(
      prs_base = gsub("^fa_|^mo_", "", variable),
      role = case_when(
        grepl("^fa_", variable) ~ "Paternal",
        grepl("^mo_", variable) ~ "Maternal",
        TRUE ~ "Proband"
      ),
      prs_base = factor(prs_base, levels = prs_order),
      role = factor(role, levels = c("Proband", "Paternal", "Maternal")),
      significance = case_when(
        p_FE < 0.001 / 18 ~ "***",
        p_FE < 0.01 / 18  ~ "**",
        p_FE < 0.05 / 18  ~ "*",
        TRUE ~ ""
      )
    )

  ggplot(plot_data, aes(x = OR_FE, y = prs_base, color = role, group = role)) +
    geom_vline(xintercept = 1, linetype = "dashed", color = "gray50", linewidth = 0.4) +
    geom_errorbarh(
      aes(xmin = CI_lower_FE, xmax = CI_upper_FE),
      height = 0.15,
      linewidth = 0.5,
      position = position_dodge(width = 0.45)
    ) +
    geom_point(size = 1.8, position = position_dodge(width = 0.45)) +
    geom_text(
      aes(label = significance),
      position = position_dodge(width = 0.45),
      vjust = -0.35,
      size = 7 / ggplot2::.pt,
      color = "black",
      fontface = "bold",
      show.legend = FALSE
    ) +
    scale_x_log10(name = "Odds Ratio") +
    scale_y_discrete(
      name = "Polygenic score",
      labels = c(
        EA = expression(PGS[EA]),
        CP = expression(PGS[CP]),
        NON_COG = expression(PGS[NON_COG])
      )
    ) +
    scale_color_manual(
      values = c(
        Proband = "#B85C5C",
        Paternal = "#6487C0",
        Maternal = "#6AA27A"
      ),
      name = NULL
    ) +
    facet_wrap(~ role, nrow = 1) +
    theme_bw(base_size = 7) +
    theme(
      panel.grid = element_blank(),
      legend.position = "none",
      axis.text = element_text(color = "black", size = 7),
      axis.title = element_text(size = 7),
      strip.text = element_text(face = "bold", size = 7),
      strip.background = element_rect(fill = "gray90", color = NA)
    )
}

plot_sensitivity_comparison <- function(meta_data,
                                        prs_name,
                                        phenotype_name,
                                        prenatal_factor = "med_cond_birth") {
  plot_data <- meta_data %>%
    filter(
      (
        prenatal_factor == "none" & strategy == "baseline" |
          prenatal_factor == !!prenatal_factor &
            strategy %in% c("adjust_prenatal_covariate", "exclude_exposed")
      ),
      variable %in% get_trio_prs_terms(prs_name),
      phenotype == phenotype_name
    ) %>%
    mutate(
      strategy_group = case_when(
        strategy == "baseline" ~ "Baseline",
        strategy == "adjust_prenatal_covariate" ~ "Adjusted",
        strategy == "exclude_exposed" ~ "Excluded"
      ),
      strategy_group = factor(strategy_group, levels = c("Baseline", "Adjusted", "Excluded")),
      role = case_when(
        variable == prs_name ~ "Direct (Proband)",
        variable == paste0("fa_", prs_name) ~ "Indirect (Paternal)",
        variable == paste0("mo_", prs_name) ~ "Indirect (Maternal)"
      ),
      role = factor(role, levels = c("Direct (Proband)", "Indirect (Paternal)", "Indirect (Maternal)")),
      ci_lower = beta_FE - 1.96 * se_FE,
      ci_upper = beta_FE + 1.96 * se_FE,
      significance = case_when(
        p_FE < 0.001 / 18 ~ "***",
        p_FE < 0.01 / 18  ~ "**",
        p_FE < 0.05 / 18  ~ "*",
        TRUE ~ ""
      )
    )

  ggplot(plot_data, aes(x = strategy_group, y = beta_FE, color = role, group = role)) +
    geom_hline(yintercept = 0, linetype = "dashed", color = "gray50", linewidth = 0.35) +
    geom_errorbar(
      aes(ymin = ci_lower, ymax = ci_upper),
      width = 0.18,
      linewidth = 0.45,
      position = position_dodge(width = 0.6)
    ) +
    geom_point(size = 1.8, position = position_dodge(width = 0.6)) +
    geom_text(
      aes(y = ci_upper, label = significance),
      position = position_dodge(width = 0.6),
      vjust = -0.35,
      size = 7 / ggplot2::.pt,
      color = "black",
      fontface = "bold",
      show.legend = FALSE
    ) +
    scale_color_manual(
      values = c(
        "Direct (Proband)" = "#3B6FB6",
        "Indirect (Paternal)" = "#E07B39",
        "Indirect (Maternal)" = "#9C6FB6"
      ),
      name = NULL
    ) +
    labs(x = NULL, y = "Effect size") +
    theme_classic(base_size = 7) +
    theme(
      legend.position = "bottom",
      axis.text = element_text(color = "black", size = 7),
      axis.title = element_text(size = 7)
    )
}

