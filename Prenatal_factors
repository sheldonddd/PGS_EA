# ============================================================
# 8. Sensitivity analyses for prenatal factors
# ============================================================

run_exclusion_sensitivity <- function(data, prenatal_factor, prs_set, Y_list) {
  if (!prenatal_factor %in% names(data)) {
    warning("Prenatal factor not found and skipped: ", prenatal_factor)
    return(NULL)
  }

  dat_filtered <- data[keep_only_unexposed(data[[prenatal_factor]]), , drop = FALSE]

  res <- run_trio_linear_all_prs(dat_filtered, prs_set, Y_list)
  if (is.null(res) || nrow(res) == 0) return(NULL)

  res$prenatal_factor <- prenatal_factor
  res$strategy <- "exclude_exposed"
  res$N_after_filter <- nrow(dat_filtered)
  res
}

run_covariate_sensitivity <- function(data, prenatal_factor, prs_set, Y_list) {
  if (!prenatal_factor %in% names(data)) {
    warning("Prenatal factor not found and skipped: ", prenatal_factor)
    return(NULL)
  }

  res <- run_trio_linear_all_prs(
    data,
    prs_set,
    Y_list,
    prenatal_covariate = prenatal_factor
  )

  if (is.null(res) || nrow(res) == 0) return(NULL)

  res$prenatal_factor <- prenatal_factor
  res$strategy <- "adjust_prenatal_covariate"
  res$N_used <- nrow(data)
  res
}

