bind_without_duplicate_columns <- function(df_left, df_right) {
  duplicated_columns <- intersect(colnames(df_left), colnames(df_right))
  df_right_unique <- df_right[, setdiff(colnames(df_right), duplicated_columns), drop = FALSE]
  cbind(df_left, df_right_unique)
}

load_and_prepare_data <- function(phenotype_file, discovery_file, replication_file) {
  phenotype_info <- read.xlsx(phenotype_file)
  discovery_info <- read.xlsx(discovery_file)
  replication_info <- read.xlsx(replication_file)

  discovery_data <- bind_without_duplicate_columns(discovery_info, phenotype_info)
  replication_data <- bind_without_duplicate_columns(replication_info, phenotype_info)

  discovery_data <- discovery_data %>%
    filter(keep == 1, asd == TRUE) %>%
    mutate(sex = factor(sex, levels = c("Female", "Male")))

  replication_data <- replication_data %>%
    filter(keep == 1, asd == TRUE) %>%
    mutate(sex = factor(sex, levels = c("Female", "Male")))

  list(
    discovery = discovery_data,
    replication = replication_data
  )
}

