# ------------------------------------------------------------------------------
# 3. Shared helper functions
# ------------------------------------------------------------------------------

to_numeric_if_possible <- function(x) {
  if (is.numeric(x)) return(x)
  suppressWarnings(as.numeric(x))
}

safe_z <- function(x) {
  as.numeric(scale(x))
}

add_rvbs_columns <- function(dat) {
  dat <- as.data.table(dat)

  required_cols <- c(
    rv_damage_cols,
    paste0(fa_prefix, rv_damage_cols),
    paste0(mo_prefix, rv_damage_cols),
    rv_syn_col,
    paste0(fa_prefix, rv_syn_col),
    paste0(mo_prefix, rv_syn_col)
  )

  missing_cols <- setdiff(required_cols, names(dat))
  if (length(missing_cols) > 0) {
    stop("Missing RVBS-related columns: ", paste(missing_cols, collapse = ", "))
  }

  dat[, RVBS_dam_child := rowSums(.SD, na.rm = TRUE), .SDcols = rv_damage_cols]
  dat[, RVBS_dam_fa    := rowSums(.SD, na.rm = TRUE), .SDcols = paste0(fa_prefix, rv_damage_cols)]
  dat[, RVBS_dam_mo    := rowSums(.SD, na.rm = TRUE), .SDcols = paste0(mo_prefix, rv_damage_cols)]

  dat[, RVBS_syn_child := get(rv_syn_col)]
  dat[, RVBS_syn_fa    := get(paste0(fa_prefix, rv_syn_col))]
  dat[, RVBS_syn_mo    := get(paste0(mo_prefix, rv_syn_col))]

  dat
}

standardize_selected_columns <- function(dat, cols) {
  dat <- as.data.table(dat)
  for (col in intersect(cols, names(dat))) {
    dat[[col]] <- to_numeric_if_possible(dat[[col]])
    if (is.numeric(dat[[col]])) {
      dat[[paste0(col, "_z")]] <- safe_z(dat[[col]])
    }
  }
  dat
}

residualize_with_pcs <- function(y, df, pcs) {
  ok <- complete.cases(cbind(y, df[, pcs, drop = FALSE]))
  residuals_out <- rep(NA_real_, length(y))

  if (sum(ok) < 5) return(residuals_out)

  model_formula <- as.formula(paste0("y ~ ", paste(pcs, collapse = " + ")))
  residuals_out[ok] <- resid(lm(model_formula, data = cbind(df[ok, pcs, drop = FALSE], y = y[ok])))
  residuals_out
}

pearson_with_ci <- function(x, y) {
  ok <- complete.cases(x, y)
  n <- sum(ok)

  if (n < 5) {
    return(data.frame(
      n = n,
      r = NA_real_,
      ci_low = NA_real_,
      ci_high = NA_real_,
      p = NA_real_
    ))
  }

  test <- suppressWarnings(cor.test(x[ok], y[ok], method = "pearson"))
  r <- unname(test$estimate)

  z <- atanh(r)
  se <- 1 / sqrt(n - 3)

  data.frame(
    n = n,
    r = r,
    ci_low = tanh(z - 1.96 * se),
    ci_high = tanh(z + 1.96 * se),
    p = test$p.value
  )
}

significance_stars <- function(p, correction_n = 1) {
  case_when(
    is.na(p) ~ "",
    p < 0.001 / correction_n ~ "***",
    p < 0.01  / correction_n ~ "**",
    p < 0.05  / correction_n ~ "*",
    TRUE ~ ""
  )
}

fixed_effect_meta <- function(res_D, res_R,
                              key_cols,
                              beta_col = "Estimate",
                              se_col = "Std. Error") {
  D <- res_D %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, any_of("R2")) %>%
    rename(beta_D = all_of(beta_col), se_D = all_of(se_col), n_D = n)

  R <- res_R %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, any_of("R2")) %>%
    rename(beta_R = all_of(beta_col), se_R = all_of(se_col), n_R = n)

  if ("R2" %in% names(D)) D <- D %>% rename(R2_D = R2)
  if ("R2" %in% names(R)) R <- R %>% rename(R2_R = R2)

  meta_data <- inner_join(D, R, by = key_cols) %>%
    filter(
      is.finite(beta_D), is.finite(beta_R),
      is.finite(se_D), is.finite(se_R),
      se_D > 0, se_R > 0
    )

  if (nrow(meta_data) == 0) return(meta_data)

  wD <- 1 / (meta_data$se_D^2)
  wR <- 1 / (meta_data$se_R^2)
  w  <- wD + wR

  beta_FE <- (wD * meta_data$beta_D + wR * meta_data$beta_R) / w
  se_FE   <- sqrt(1 / w)
  z_FE    <- beta_FE / se_FE
  p_FE    <- 2 * pnorm(-abs(z_FE))

  meta_data %>%
    mutate(
      beta_FE = beta_FE,
      se_FE = se_FE,
      z_FE = z_FE,
      p_FE = p_FE
    )
}


# ------------------------------------------------------------------------------
# 4. RVBS-PGS correlation analysis
# ------------------------------------------------------------------------------

run_rvbs_pgs_correlation <- function(df, dataset_label = "Discovery") {
  df <- as.data.frame(add_rvbs_columns(df))

  fa_pc_cols <- paste0(fa_prefix, pc_cols)
  mo_pc_cols <- paste0(mo_prefix, pc_cols)

  required_cols <- c(
    prs_order, pc_cols,
    paste0(fa_prefix, prs_order), fa_pc_cols,
    paste0(mo_prefix, prs_order), mo_pc_cols
  )

  missing_cols <- setdiff(required_cols, colnames(df))
  if (length(missing_cols) > 0) {
    stop("Missing columns for correlation analysis: ", paste(missing_cols, collapse = ", "))
  }

  df$RVBS_dam_child_r <- residualize_with_pcs(df$RVBS_dam_child, df, pc_cols)
  df$RVBS_syn_child_r <- residualize_with_pcs(df$RVBS_syn_child, df, pc_cols)

  df$RVBS_dam_fa_r <- residualize_with_pcs(df$RVBS_dam_fa, df, fa_pc_cols)
  df$RVBS_syn_fa_r <- residualize_with_pcs(df$RVBS_syn_fa, df, fa_pc_cols)

  df$RVBS_dam_mo_r <- residualize_with_pcs(df$RVBS_dam_mo, df, mo_pc_cols)
  df$RVBS_syn_mo_r <- residualize_with_pcs(df$RVBS_syn_mo, df, mo_pc_cols)

  for (prs in prs_order) {
    df[[paste0(prs, "_r")]] <- residualize_with_pcs(df[[prs]], df, pc_cols)
    df[[paste0("fa_", prs, "_r")]] <- residualize_with_pcs(df[[paste0(fa_prefix, prs)]], df, fa_pc_cols)
    df[[paste0("mo_", prs, "_r")]] <- residualize_with_pcs(df[[paste0(mo_prefix, prs)]], df, mo_pc_cols)
  }

  calculate_one_correlation <- function(variant, group, prs) {
    if (variant == "Damaging") {
      rv_child <- df$RVBS_dam_child_r
      rv_fa <- df$RVBS_dam_fa_r
      rv_mo <- df$RVBS_dam_mo_r
    } else {
      rv_child <- df$RVBS_syn_child_r
      rv_fa <- df$RVBS_syn_fa_r
      rv_mo <- df$RVBS_syn_mo_r
    }

    prs_child <- df[[paste0(prs, "_r")]]
    prs_fa <- df[[paste0("fa_", prs, "_r")]]
    prs_mo <- df[[paste0("mo_", prs, "_r")]]

    if (group == "Proband (within)") {
      x <- rv_child
      y <- prs_child
    } else if (group == "Parents (within)") {
      x <- c(rv_fa, rv_mo)
      y <- c(prs_fa, prs_mo)
    } else if (group == "Cross-parent") {
      x <- c(rv_fa, rv_mo)
      y <- c(prs_mo, prs_fa)
    } else {
      stop("Unknown correlation group: ", group)
    }

    cbind(
      dataset = dataset_label,
      group = group,
      variant = variant,
      PRS = prs,
      pearson_with_ci(x, y)
    )
  }

  bind_rows(lapply(prs_order, function(prs) {
    bind_rows(
      calculate_one_correlation("Damaging",   "Proband (within)", prs),
      calculate_one_correlation("Synonymous", "Proband (within)", prs),
      calculate_one_correlation("Damaging",   "Parents (within)", prs),
      calculate_one_correlation("Synonymous", "Parents (within)", prs),
      calculate_one_correlation("Damaging",   "Cross-parent", prs),
      calculate_one_correlation("Synonymous", "Cross-parent", prs)
    )
  })) %>%
    mutate(star = significance_stars(p, correction_n = 6))
}

meta_correlation_fixed <- function(df_one_test) {
  df <- df_one_test %>% filter(!is.na(r), !is.na(n), n > 3)

  if (nrow(df) == 0) {
    return(data.frame(
      r_meta = NA_real_,
      ci_low = NA_real_,
      ci_high = NA_real_,
      p_meta = NA_real_,
      k = 0
    ))
  }

  z <- atanh(df$r)
  w <- df$n - 3

  z_meta <- sum(w * z) / sum(w)
  se_meta <- sqrt(1 / sum(w))
  z_stat <- z_meta / se_meta

  data.frame(
    r_meta = tanh(z_meta),
    ci_low = tanh(z_meta - 1.96 * se_meta),
    ci_high = tanh(z_meta + 1.96 * se_meta),
    p_meta = 2 * pnorm(-abs(z_stat)),
    k = nrow(df)
  )
}

run_correlation_meta <- function(res_D, res_R) {
  bind_rows(res_D, res_R) %>%
    group_by(group, variant, PRS) %>%
    group_modify(~ meta_correlation_fixed(.x)) %>%
    ungroup() %>%
    mutate(
      dataset = "Meta",
      r = r_meta,
      p = p_meta,
      star = significance_stars(p_meta, correction_n = 6)
    ) %>%
    select(dataset, group, variant, PRS, r, ci_low, ci_high, p, star, k)
}

