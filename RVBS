# ------------------------------------------------------------------------------
# 5. Continuous phenotype models with PGS and RVBS
# ------------------------------------------------------------------------------

run_multivariate_linear_with_rvbs <- function(data,
                                             phenotype_list,
                                             prs_name,
                                             pc_columns = pc_cols) {
  dat <- as.data.table(add_rvbs_columns(data))

  x_interest <- c(
    prs_name,
    paste0(fa_prefix, prs_name),
    paste0(mo_prefix, prs_name),
    "RVBS_dam_child",
    "RVBS_dam_fa",
    "RVBS_dam_mo"
  )

  numeric_cols <- unique(c(
    phenotype_list,
    paste0(phenotype_list, "_age"),
    x_interest,
    pc_columns
  ))

  for (col in intersect(numeric_cols, names(dat))) {
    if (col != "sex") dat[[col]] <- to_numeric_if_possible(dat[[col]])
  }

  dat <- standardize_selected_columns(dat, c(phenotype_list, x_interest, pc_columns))

  x_z <- paste0(x_interest, "_z")
  x_z <- intersect(x_z, names(dat))

  if (length(x_z) == 0) {
    stop("No valid numeric predictors are available for linear modeling.")
  }

  output <- list()

  for (phenotype in phenotype_list) {
    if (!phenotype %in% names(dat)) next
    if (!is.numeric(dat[[phenotype]])) next

    phenotype_z <- paste0(phenotype, "_z")
    dat[[phenotype_z]] <- safe_z(dat[[phenotype]])

    age_var <- paste0(phenotype, "_age")

    predictors <- c(
      x_z,
      "sex",
      if (age_var %in% names(dat)) age_var else NULL,
      intersect(paste0(pc_columns, "_z"), names(dat))
    )

    model_formula <- as.formula(paste0(phenotype_z, " ~ ", paste(predictors, collapse = " + ")))
    fit <- lm(model_formula, data = dat)
    model_summary <- summary(fit)

    coef_table <- as.data.frame(model_summary$coefficients)
    coef_table$variable <- rownames(coef_table)

    selected <- coef_table[coef_table$variable %in% x_z, , drop = FALSE]
    if (nrow(selected) == 0) next

    selected$variable <- sub("_z$", "", selected$variable)
    selected$phenotype <- phenotype
    selected$R2 <- model_summary$r.squared
    selected$n <- nobs(fit)
    selected$PRS <- prs_name

    output[[phenotype]] <- selected
  }

  res <- do.call(rbind, output)
  rownames(res) <- NULL
  res
}

run_all_linear_models <- function(data, phenotype_list, prs_set = prs_order) {
  do.call(rbind, lapply(prs_set, function(prs) {
    run_multivariate_linear_with_rvbs(
      data = data,
      phenotype_list = phenotype_list,
      prs_name = prs
    )
  }))
}

plot_linear_forest_one <- function(prs_name,
                                   phenotype_name,
                                   meta_data,
                                   x_limits = NULL) {
  target_vars <- c(
    prs_name,
    paste0(fa_prefix, prs_name),
    paste0(mo_prefix, prs_name),
    "RVBS_dam_child",
    "RVBS_dam_fa",
    "RVBS_dam_mo"
  )

  plot_data <- meta_data %>%
    filter(PRS == prs_name, phenotype == phenotype_name, variable %in% target_vars) %>%
    mutate(
      variable_label = case_when(
        variable == prs_name ~ paste0("PGS[", prs_name, "]"),
        variable == paste0(fa_prefix, prs_name) ~ paste0("fa_PGS[", prs_name, "]"),
        variable == paste0(mo_prefix, prs_name) ~ paste0("mo_PGS[", prs_name, "]"),
        variable == "RVBS_dam_child" ~ "RVBS",
        variable == "RVBS_dam_fa" ~ "fa_RVBS",
        variable == "RVBS_dam_mo" ~ "mo_RVBS",
        TRUE ~ variable
      ),
      type = case_when(
        variable %in% c(prs_name, paste0(fa_prefix, prs_name), paste0(mo_prefix, prs_name)) ~ "PGS",
        variable %in% c("RVBS_dam_child", "RVBS_dam_fa", "RVBS_dam_mo") ~ "RVBS",
        TRUE ~ NA_character_
      ),
      variable_label = factor(
        variable_label,
        levels = c(
          paste0("PGS[", prs_name, "]"),
          paste0("fa_PGS[", prs_name, "]"),
          paste0("mo_PGS[", prs_name, "]"),
          "RVBS",
          "fa_RVBS",
          "mo_RVBS"
        )
      ),
      ci_lower = beta_FE - 1.96 * se_FE,
      ci_upper = beta_FE + 1.96 * se_FE,
      significance = significance_stars(p_FE, correction_n = 24)
    )

  if (nrow(plot_data) == 0) {
    stop("No matching data found for ", prs_name, " and ", phenotype_name)
  }

  if (is.null(x_limits)) {
    xr <- range(c(plot_data$ci_lower, plot_data$ci_upper), na.rm = TRUE)
    pad <- diff(xr) * 0.12
    if (is.na(pad) || pad == 0) pad <- 0.05
    x_limits <- c(xr[1] - pad, xr[2] + pad)
  }

  phenotype_title <- case_when(
    phenotype_name == "scq" ~ "SCQ",
    phenotype_name == "srs" ~ "SRS",
    phenotype_name == "rbsr" ~ "RBSR",
    phenotype_name == "vabs" ~ "VABS",
    phenotype_name == "fsiq" ~ "FSIQ",
    phenotype_name == "dcdq" ~ "DCDQ",
    TRUE ~ toupper(phenotype_name)
  )

  y_breaks <- levels(plot_data$variable_label)
  y_labels <- c(
    setNames(
      lapply(y_breaks[grepl("PGS\\[", y_breaks)], function(x) parse(text = x)[[1]]),
      y_breaks[grepl("PGS\\[", y_breaks)]
    ),
    setNames(as.list(y_breaks[!grepl("PGS\\[", y_breaks)]), y_breaks[!grepl("PGS\\[", y_breaks)])
  )

  ggplot(plot_data, aes(x = beta_FE, y = variable_label, color = type)) +
    geom_vline(xintercept = 0, linetype = "dashed", color = "grey60", linewidth = 0.45) +
    geom_errorbarh(aes(xmin = ci_lower, xmax = ci_upper), height = 0.12, linewidth = 0.8) +
    geom_point(size = 2, shape = 16) +
    geom_text(
      aes(label = significance),
      nudge_y = 0.28,
      size = 7 / ggplot2::.pt,
      color = "black",
      fontface = "bold",
      show.legend = FALSE
    ) +
    scale_y_discrete(breaks = y_breaks, labels = y_labels) +
    scale_color_manual(
      values = c("PGS" = "#B24A5A", "RVBS" = "#7FA6C9"),
      breaks = c("PGS", "RVBS")
    ) +
    coord_cartesian(xlim = x_limits, clip = "off") +
    labs(
      title = phenotype_title,
      x = "Effect size",
      y = NULL,
      color = NULL
    ) +
    theme_classic(base_size = 7) +
    theme(
      plot.title = element_text(hjust = 0.5, face = "bold", size = 7, margin = margin(t = 0, b = 2)),
      axis.text.x = element_text(size = 7, color = "black"),
      axis.text.y = element_text(size = 7, color = "black"),
      axis.title.x = element_text(size = 7, margin = margin(t = 8)),
      axis.line = element_line(linewidth = 0.5, color = "black"),
      axis.ticks = element_line(linewidth = 0.4, color = "black"),
      axis.ticks.length = unit(0.18, "cm"),
      panel.grid.major = element_blank(),
      panel.grid.minor = element_blank(),
      legend.position = "right",
      legend.text = element_text(size = 7),
      legend.title = element_text(size = 7),
      plot.margin = margin(6, 16, 6, 8)
    )
}

plot_linear_forest_multi_panel <- function(prs_name,
                                           phenotypes,
                                           meta_data,
                                           ncol = 2) {
  target_vars <- c(
    prs_name,
    paste0(fa_prefix, prs_name),
    paste0(mo_prefix, prs_name),
    "RVBS_dam_child",
    "RVBS_dam_fa",
    "RVBS_dam_mo"
  )

  all_data <- meta_data %>%
    filter(PRS == prs_name, phenotype %in% phenotypes, variable %in% target_vars) %>%
    mutate(
      ci_lower = beta_FE - 1.96 * se_FE,
      ci_upper = beta_FE + 1.96 * se_FE
    )

  xr <- range(c(all_data$ci_lower, all_data$ci_upper), na.rm = TRUE)
  pad <- diff(xr) * 0.12
  if (is.na(pad) || pad == 0) pad <- 0.05
  x_limits <- c(xr[1] - pad, xr[2] + pad)

  plot_list <- lapply(phenotypes, function(pheno) {
    plot_linear_forest_one(
      prs_name = prs_name,
      phenotype_name = pheno,
      meta_data = meta_data,
      x_limits = x_limits
    )
  })

  wrap_plots(plotlist = plot_list, ncol = ncol) +
    plot_layout(guides = "collect") &
    theme(
      legend.position = "right",
      legend.direction = "vertical",
      legend.title = element_blank(),
      legend.text = element_text(size = 7)
    )
}


