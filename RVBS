# 6. Binary phenotype models with PGS and RVBS
# ------------------------------------------------------------------------------

run_multivariate_logistic_with_rvbs <- function(data,
                                                phenotype_list,
                                                prs_name,
                                                age_col = "med_age",
                                                pc_columns = pc_cols) {
  dat <- as.data.table(add_rvbs_columns(data))

  if (!"sex" %in% names(dat)) stop("Missing sex column.")
  if (!age_col %in% names(dat)) stop("Missing age column: ", age_col)

  dat[["sex"]] <- as.factor(dat[["sex"]])
  if (all(c("Female", "Male") %in% levels(dat[["sex"]]))) {
    dat[["sex"]] <- factor(dat[["sex"]], levels = c("Female", "Male"))
  }

  x_interest <- c(
    prs_name,
    paste0(fa_prefix, prs_name),
    paste0(mo_prefix, prs_name),
    "RVBS_dam_child",
    "RVBS_dam_fa",
    "RVBS_dam_mo"
  )

  numeric_cols <- unique(c(phenotype_list, x_interest, age_col, pc_columns))
  for (col in intersect(numeric_cols, names(dat))) {
    if (col != "sex") dat[[col]] <- to_numeric_if_possible(dat[[col]])
  }

  dat <- standardize_selected_columns(dat, c(x_interest, pc_columns))
  x_z <- intersect(paste0(x_interest, "_z"), names(dat))

  if (length(x_z) == 0) {
    stop("No valid numeric predictors are available for logistic modeling.")
  }

  output <- list()

  for (phenotype in phenotype_list) {
    if (!phenotype %in% names(dat)) {
      warning("Phenotype not found; skipped: ", phenotype)
      next
    }

    dat[[phenotype]] <- as.numeric(dat[[phenotype]])

    predictors <- c(
      x_z,
      "sex",
      age_col,
      intersect(paste0(pc_columns, "_z"), names(dat))
    )

    model_formula <- as.formula(paste0(phenotype, " ~ ", paste(predictors, collapse = " + ")))
    fit <- glm(model_formula, data = dat, family = binomial)
    model_summary <- summary(fit)

    coef_table <- as.data.frame(model_summary$coefficients)
    coef_table$variable <- rownames(coef_table)

    selected <- coef_table[coef_table$variable %in% x_z, , drop = FALSE]
    if (nrow(selected) == 0) next

    selected$OR <- exp(selected$Estimate)
    selected$CI_lower <- exp(selected$Estimate - 1.96 * selected$`Std. Error`)
    selected$CI_upper <- exp(selected$Estimate + 1.96 * selected$`Std. Error`)

    null_fit <- glm(as.formula(paste0(phenotype, " ~ 1")), data = dat, family = binomial)
    selected$R2 <- 1 - as.numeric(logLik(fit) / logLik(null_fit))

    selected$variable <- sub("_z$", "", selected$variable)
    selected$phenotype <- phenotype
    selected$phenotype_label <- unname(binary_pheno_labels[phenotype])
    selected$n <- nobs(fit)
    selected$PRS <- prs_name

    output[[phenotype]] <- selected
  }

  res <- do.call(rbind, output)
  rownames(res) <- NULL
  res
}

run_all_logistic_models <- function(data, phenotype_list, prs_set = prs_order) {
  do.call(rbind, lapply(prs_set, function(prs) {
    run_multivariate_logistic_with_rvbs(
      data = data,
      phenotype_list = phenotype_list,
      prs_name = prs
    )
  }))
}

add_variable_role <- function(df) {
  df %>%
    mutate(
      role = case_when(
        variable == "RVBS_dam_child" ~ "Proband_RVBS",
        variable == "RVBS_dam_fa" ~ "Father_RVBS",
        variable == "RVBS_dam_mo" ~ "Mother_RVBS",
        grepl("^fa_", variable) ~ "Father",
        grepl("^mo_", variable) ~ "Mother",
        TRUE ~ "Proband"
      ),
      variable_type = ifelse(grepl("RVBS", variable), "RVBS", "PGS"),
      prs_base = gsub("^fa_|^mo_", "", variable)
    )
}

meta_logistic_with_or <- function(res_D, res_R,
                                  key_cols = c("phenotype", "PRS", "variable", "phenotype_label"),
                                  beta_col = "Estimate",
                                  se_col = "Std. Error") {
  meta_data <- fixed_effect_meta(
    res_D = res_D,
    res_R = res_R,
    key_cols = key_cols,
    beta_col = beta_col,
    se_col = se_col
  )

  if (nrow(meta_data) == 0) return(meta_data)

  meta_data %>%
    mutate(
      OR_FE = exp(beta_FE),
      CI_lower_FE = exp(beta_FE - 1.96 * se_FE),
      CI_upper_FE = exp(beta_FE + 1.96 * se_FE)
    )
}

plot_logistic_forest_one <- function(prs_name,
                                     phenotype_name,
                                     meta_data,
                                     x_limits = NULL,
                                     show_y_axis = TRUE) {
  target_vars <- c(
    prs_name,
    paste0(fa_prefix, prs_name),
    paste0(mo_prefix, prs_name),
    "RVBS_dam_child",
    "RVBS_dam_fa",
    "RVBS_dam_mo"
  )

  plot_data <- meta_data %>%
    filter(PRS == prs_name, phenotype == phenotype_name, variable %in% target_vars) %>%
    mutate(
      variable_label = case_when(
        variable == prs_name ~ paste0("PGS[", prs_name, "]"),
        variable == paste0(fa_prefix, prs_name) ~ paste0("fa_PGS[", prs_name, "]"),
        variable == paste0(mo_prefix, prs_name) ~ paste0("mo_PGS[", prs_name, "]"),
        variable == "RVBS_dam_child" ~ "RVBS",
        variable == "RVBS_dam_fa" ~ "fa_RVBS",
        variable == "RVBS_dam_mo" ~ "mo_RVBS",
        TRUE ~ variable
      ),
      type = case_when(
        variable %in% c(prs_name, paste0(fa_prefix, prs_name), paste0(mo_prefix, prs_name)) ~ "PGS",
        variable %in% c("RVBS_dam_child", "RVBS_dam_fa", "RVBS_dam_mo") ~ "RVBS",
        TRUE ~ NA_character_
      ),
      variable_label = factor(
        variable_label,
        levels = c(
          paste0("PGS[", prs_name, "]"),
          paste0("fa_PGS[", prs_name, "]"),
          paste0("mo_PGS[", prs_name, "]"),
          "RVBS",
          "fa_RVBS",
          "mo_RVBS"
        )
      ),
      significance = significance_stars(p_FE, correction_n = 20)
    )

  if (nrow(plot_data) == 0) {
    stop("No matching data found for ", prs_name, " and ", phenotype_name)
  }

  phenotype_label <- unique(plot_data$phenotype_label)
  if (length(phenotype_label) == 0 || all(is.na(phenotype_label))) {
    phenotype_label <- phenotype_name
  } else {
    phenotype_label <- phenotype_label[1]
  }

  if (is.null(x_limits)) {
    or_min <- min(plot_data$CI_lower_FE, na.rm = TRUE)
    or_max <- max(plot_data$CI_upper_FE, na.rm = TRUE)
    or_range <- or_max - or_min
    x_limits <- c(max(0.1, or_min - 0.1 * or_range), or_max + 0.3 * or_range)
  }

  y_breaks <- levels(plot_data$variable_label)
  y_labels <- c(
    setNames(
      lapply(y_breaks[grepl("PGS\\[", y_breaks)], function(x) parse(text = x)[[1]]),
      y_breaks[grepl("PGS\\[", y_breaks)]
    ),
    setNames(as.list(y_breaks[!grepl("PGS\\[", y_breaks)]), y_breaks[!grepl("PGS\\[", y_breaks)])
  )

  p <- ggplot(plot_data, aes(x = OR_FE, y = variable_label, color = type)) +
    geom_vline(xintercept = 1, linetype = "dashed", color = "gray60", linewidth = 0.3) +
    geom_errorbarh(aes(xmin = CI_lower_FE, xmax = CI_upper_FE), height = 0.12, linewidth = 0.45) +
    geom_point(size = 1.6, shape = 16) +
    geom_text(
      aes(label = significance),
      nudge_y = 0.28,
      size = 2.3,
      color = "black",
      fontface = "bold",
      show.legend = FALSE
    ) +
    scale_y_discrete(breaks = y_breaks, labels = y_labels) +
    scale_color_manual(
      values = c("PGS" = "#4DBBD5", "RVBS" = "#B07AA1"),
      breaks = c("PGS", "RVBS")
    ) +
    scale_x_continuous(limits = x_limits, trans = "log10", breaks = 1) +
    labs(
      x = NULL,
      y = NULL,
      title = phenotype_label,
      color = NULL
    ) +
    theme_classic(base_size = 7) +
    theme(
      plot.title = element_text(hjust = 0.5, face = "bold", size = 7, margin = margin(t = 0, b = 2)),
      axis.text.x = element_text(size = 7, color = "black"),
      axis.text.y = element_text(size = 7, color = "black"),
      axis.title.x = element_blank(),
      axis.line = element_line(linewidth = 0.3, color = "black"),
      axis.ticks = element_line(linewidth = 0.3, color = "black"),
      axis.ticks.length = unit(0.12, "cm"),
      panel.grid.major = element_blank(),
      panel.grid.minor = element_blank(),
      legend.position = "right",
      legend.text = element_text(size = 7),
      plot.margin = margin(4, 6, 4, 4)
    )

  if (!show_y_axis) {
    p <- p +
      theme(
        axis.text.y = element_blank(),
        axis.ticks.y = element_blank(),
        axis.line.y = element_blank()
      )
  }

  p
}

plot_logistic_forest_multi_panel <- function(prs_name,
                                             phenotypes,
                                             meta_data,
                                             ncol = 2) {
  plot_list <- lapply(seq_along(phenotypes), function(i) {
    plot_logistic_forest_one(
      prs_name = prs_name,
      phenotype_name = phenotypes[i],
      meta_data = meta_data,
      show_y_axis = ((i - 1) %% ncol == 0)
    )
  })

  combined_plot <- wrap_plots(plotlist = plot_list, ncol = ncol) +
    plot_layout(guides = "collect") &
    theme(
      legend.position = "right",
      legend.direction = "vertical",
      legend.title = element_blank(),
      legend.text = element_text(size = 7)
    )

  x_title_plot <- ggplot() +
    annotate("text", x = 1, y = 1, label = "Odds Ratio", size = 2.5) +
    theme_void() +
    theme(plot.margin = margin(0, 0, 2, 0))

  combined_plot / x_title_plot + plot_layout(heights = c(20, 1))
}


