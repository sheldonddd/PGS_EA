plot_trio_diagnosis_age_forest <- function(meta_trio_results) {
  plot_data <- meta_trio_results %>%
    filter(phenotype == outcome_dx) %>%
    mutate(
      group = case_when(
        variable == PRS ~ "Proband",
        variable == paste0("fa_", PRS) ~ "Father",
        variable == paste0("mo_", PRS) ~ "Mother",
        TRUE ~ NA_character_
      ),
      group = factor(group, levels = c("Proband", "Father", "Mother")),
      PRS = factor(PRS, levels = prs_set),
      ci_low = beta_FE - 1.96 * se_FE,
      ci_high = beta_FE + 1.96 * se_FE,
      sig = case_when(
        p_FE < 0.001 / 3 ~ "***",
        p_FE < 0.01 / 3 ~ "**",
        p_FE < 0.05 / 3 ~ "*",
        TRUE ~ ""
      ),
      x_num = as.numeric(PRS),
      x_pos = x_num + case_when(group == "Proband" ~ -0.22, group == "Father" ~ 0, group == "Mother" ~ 0.22)
    ) %>%
    filter(!is.na(group))

  y_pad <- 0.04 * (max(plot_data$ci_high, na.rm = TRUE) - min(plot_data$ci_low, na.rm = TRUE))

  ggplot(plot_data, aes(x = x_pos, y = beta_FE, color = group)) +
    geom_hline(yintercept = 0, linetype = "dashed", color = "grey55", linewidth = 0.3) +
    geom_errorbar(aes(ymin = ci_low, ymax = ci_high), width = 0.06, linewidth = 0.8) +
    geom_point(size = 2.4) +
    geom_text(aes(y = ci_high + y_pad, label = sig), color = "black", size = 7 / ggplot2::.pt, vjust = 0) +
    scale_x_continuous(
      breaks = seq_along(prs_set),
      labels = parse(text = c('PGS["EA"]', 'PGS["CP"]', 'PGS["NON_COG"]')),
      expand = expansion(mult = c(0.06, 0.06))
    ) +
    scale_color_manual(
      values = c("Proband" = "#C44E52", "Father" = "#4C72B0", "Mother" = "#55A868"),
      labels = c("Proband" = "Direct (Proband)", "Father" = "Indirect (Paternal)", "Mother" = "Indirect (Maternal)")
    ) +
    labs(x = NULL, y = "Effect size", color = NULL) +
    theme_classic(base_size = 7) +
    theme(
      axis.text = element_text(size = 7, color = "black"),
      axis.title.y = element_text(size = 7, color = "black"),
      legend.position = "right",
      legend.text = element_text(size = 7, color = "black")
    )
}

plot_sem_mediation_panel <- function(sem_meta_results) {
  plot_data <- sem_meta_results %>%
    filter(effect %in% c("indirect", "direct")) %>%
    mutate(
      effect_type = recode(effect, indirect = "Mediated", direct = "Unmediated"),
      mediator = factor(toupper(mediator), levels = toupper(mediators)),
      treat_var = factor(treat_var,
                         levels = c("fa_NON_COG", "mo_NON_COG", "fa_CP", "mo_CP", "fa_EA", "mo_EA")),
      pgs_group = case_when(
        grepl("EA$", as.character(treat_var)) ~ "EA",
        grepl("CP$", as.character(treat_var)) ~ "CP",
        grepl("NON_COG$", as.character(treat_var)) ~ "NON_COG"
      ),
      fill_type = paste(pgs_group, effect_type, sep = "_"),
      sig = case_when(p_FE < 0.05 / 15 ~ "**", p_FE < 0.05 ~ "*", TRUE ~ "")
    )

  ggplot(plot_data, aes(x = est_FE, y = treat_var, fill = fill_type, alpha = effect_type)) +
    geom_vline(xintercept = 0, linewidth = 0.3, color = "black") +
    geom_col(width = 0.64, color = "black", linewidth = 0.3) +
    geom_text(data = plot_data %>% filter(sig != ""), aes(label = sig),
              position = position_stack(vjust = 0.5, reverse = TRUE),
              size = 7 / ggplot2::.pt, color = "black", inherit.aes = TRUE) +
    facet_wrap(~ mediator, ncol = 5, scales = "free_x") +
    scale_fill_manual(
      values = c(
        "EA_Mediated" = "#8FB6E8", "EA_Unmediated" = "#2F6DB3",
        "CP_Mediated" = "#92C98A", "CP_Unmediated" = "#4E9B47",
        "NON_COG_Mediated" = "#F3B37A", "NON_COG_Unmediated" = "#D97A1E"
      ),
      guide = "none"
    ) +
    scale_alpha_manual(values = c("Mediated" = 0.4, "Unmediated" = 1), name = NULL) +
    labs(x = "Effect size", y = "PGS") +
    theme_bw(base_size = 7) +
    theme(panel.grid = element_blank(), legend.position = "top")
}

# =============================================================================
# 6. Run analysis
# =============================================================================

asd_data <- prepare_asd_data(phenotype_file, discovery_file, replication_file)
info_D_phe_asd <- asd_data$discovery
info_R_phe_asd <- asd_data$replication

# Single-predictor association models
res_D_single <- run_single_predictor_linear_models(info_D_phe_asd, outcome_dx, prs_variables, pc_n = pc_n)
res_R_single <- run_single_predictor_linear_models(info_R_phe_asd, outcome_dx, prs_variables, pc_n = pc_n)
meta_single_dx <- meta_two_studies_linear(res_D_single, res_R_single, key_cols = c("phenotype", "variable"),
                                          beta_col = "beta", se_col = "se")

# Trio models including offspring, paternal, and maternal PGSs jointly
res_D_trio <- run_trio_linear_models(info_D_phe_asd, outcome_dx, prs_set, pc_n = pc_n)
res_R_trio <- run_trio_linear_models(info_R_phe_asd, outcome_dx, prs_set, pc_n = pc_n)
meta_trio_dx <- meta_two_studies_linear(res_D_trio, res_R_trio, key_cols = c("phenotype", "PRS", "variable"))

# SEM mediation models
sem_mediation_meta <- run_batch_sem_mediation(info_D_phe_asd, info_R_phe_asd, outcome_dx, mediators, prs_set)

# Plots
p_trio_diagnosis_age <- plot_trio_diagnosis_age_forest(meta_trio_dx)
p_sem_mediation <- plot_sem_mediation_panel(sem_mediation_meta)

# Export results
write.xlsx(meta_single_dx, file.path(output_dir, "diagnosis_age_single_predictor_meta.xlsx"))
write.xlsx(meta_trio_dx, file.path(output_dir, "diagnosis_age_trio_model_meta.xlsx"))
write.xlsx(sem_mediation_meta, file.path(output_dir, "diagnosis_age_sem_mediation_meta.xlsx"))

# Print plots in interactive sessions
print(p_trio_diagnosis_age)
print(p_sem_mediation)
