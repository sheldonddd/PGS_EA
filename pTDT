# ------------------------------------------------------------------------------
# 9. Plotting function for one pTDT meta-analysis panel
# ------------------------------------------------------------------------------

plot_meta_ptdt_combined_ng <- function(meta_asd, meta_sib, title = NULL,
                                       y_limits = NULL,
                                       show_legend = TRUE) {
  plot_df <- bind_rows(
    meta_asd %>% mutate(group2 = "ASD"),
    meta_sib %>% mutate(group2 = "Sibling")
  )

  prs_order <- c("EA", "CP", "NON_COG")

  plot_df <- plot_df %>%
    mutate(
      PRS = factor(PRS, levels = prs_order),
      group2 = factor(group2, levels = c("ASD", "Sibling"))
    ) %>%
    arrange(PRS, group2) %>%
    mutate(
      sig = case_when(
        p_meta < 0.001 / 6 ~ "***",
        p_meta < 0.01  / 6 ~ "**",
        p_meta < 0.05  / 6 ~ "*",
        TRUE ~ ""
      )
    )

  # Return an empty placeholder plot if no valid results are available.
  if (nrow(plot_df) == 0) {
    return(
      ggplot() +
        theme_void(base_size = 7) +
        labs(title = title) +
        annotate(
          "text",
          x = 0,
          y = 0,
          label = "No valid results",
          size = 7 / ggplot2::.pt
        )
    )
  }

  # Determine the vertical location of significance labels.
  y_range <- max(plot_df$ci_upper, na.rm = TRUE) -
    min(plot_df$ci_lower, na.rm = TRUE)

  if (!is.finite(y_range) || y_range == 0) y_range <- 0.1

  y_pad <- 0.06 * y_range

  plot_df <- plot_df %>%
    mutate(sig_y = ci_upper + y_pad)

  dodge <- position_dodge(width = 0.42)

  # Use an automatic y-axis range unless a shared range is provided.
  if (is.null(y_limits)) {
    y_limits <- c(
      min(plot_df$ci_lower, na.rm = TRUE) - 0.08 * y_range,
      max(plot_df$sig_y,   na.rm = TRUE) + 0.10 * y_range
    )
  }

  p <- ggplot(plot_df, aes(x = PRS, y = beta_meta, group = group2)) +
    geom_hline(
      yintercept = 0,
      linetype = "dashed",
      linewidth = 0.38,
      color = "black"
    ) +
    geom_errorbar(
      aes(ymin = ci_lower, ymax = ci_upper),
      width = 0.10,
      linewidth = 0.60,
      color = "black",
      position = dodge
    ) +
    geom_point(
      aes(fill = group2),
      shape = 21,
      size = 3.1,
      stroke = 0.60,
      color = "black",
      position = dodge
    ) +
    geom_text(
      aes(y = sig_y, label = sig),
      position = dodge,
      size = 7 / ggplot2::.pt,
      color = "black",
      vjust = 0
    ) +
    scale_x_discrete(
      breaks = c("EA", "CP", "NON_COG"),
      labels = c(
        expression(PGS[EA]),
        expression(PGS[CP]),
        expression(PGS[NON-COG])
      )
    ) +
    scale_fill_manual(
      values = c(
        "ASD"     = "#4C78A8",
        "Sibling" = "#B8B8B8"
      )
    ) +
    labs(
      title = title,
      x = NULL,
      y = "PGS deviation",
      fill = NULL
    ) +
    coord_cartesian(
      ylim = y_limits,
      clip = "off"
    ) +
    theme_classic(base_size = 7) +
    theme(
      axis.line = element_line(linewidth = 0.6, color = "black"),
      axis.ticks = element_line(linewidth = 0.5, color = "black"),
      axis.ticks.length = unit(2.2, "mm"),

      axis.text.x = element_text(size = 7, color = "black"),
      axis.text.y = element_text(size = 7, color = "black"),
      axis.title.y = element_text(size = 7, color = "black"),

      plot.title = element_text(size = 7, face = "bold", hjust = 0.5),

      legend.position = if (show_legend) "top" else "none",
      legend.direction = "horizontal",
      legend.text = element_text(size = 7, color = "black"),
      legend.key.size = unit(0.7, "lines"),

      plot.margin = margin(8, 14, 8, 8)
    ) +
    guides(
      fill = guide_legend(override.aes = list(shape = 21, size = 3))
    )

  return(p)
}

# ------------------------------------------------------------------------------
# 10. Compute a shared y-axis range for all three panels
# ------------------------------------------------------------------------------

get_common_ylim <- function(...) {
  lst <- list(...)

  all_df <- bind_rows(lapply(lst, function(x) {
    bind_rows(
      x$meta_asd %>% mutate(group2 = "ASD"),
      x$meta_sib %>% mutate(group2 = "Sibling")
    )
  }))

  if (nrow(all_df) == 0) return(c(-0.2, 0.2))

  y_range <- max(all_df$ci_upper, na.rm = TRUE) -
    min(all_df$ci_lower, na.rm = TRUE)

  if (!is.finite(y_range) || y_range == 0) y_range <- 0.1

  all_df <- all_df %>%
    mutate(
      sig = case_when(
        p_meta < 0.001 / 6 ~ "***",
        p_meta < 0.01  / 6 ~ "**",
        p_meta < 0.05  / 6 ~ "*",
        TRUE ~ ""
      ),
      sig_y = ci_upper + 0.06 * y_range
    )

  c(
    min(all_df$ci_lower, na.rm = TRUE) - 0.08 * y_range,
    max(all_df$sig_y,   na.rm = TRUE) + 0.10 * y_range
  )
}

common_ylim <- get_common_ylim(ptdt_overall, ptdt_male, ptdt_female)

# ------------------------------------------------------------------------------
# 11. Generate sex-stratified pTDT meta-analysis plots
# ------------------------------------------------------------------------------

p_overall <- plot_meta_ptdt_combined_ng(
  meta_asd = ptdt_overall$meta_asd,
  meta_sib = ptdt_overall$meta_sib,
  title = "Overall",
  y_limits = common_ylim,
  show_legend = TRUE
)

p_male <- plot_meta_ptdt_combined_ng(
  meta_asd = ptdt_male$meta_asd,
  meta_sib = ptdt_male$meta_sib,
  title = "Male",
  y_limits = common_ylim,
  show_legend = FALSE
)

p_female <- plot_meta_ptdt_combined_ng(
  meta_asd = ptdt_female$meta_asd,
  meta_sib = ptdt_female$meta_sib,
  title = "Female",
  y_limits = common_ylim,
  show_legend = FALSE
)

# Combine the three panels into one figure.
p_ptdt_sex_panel <- p_overall + p_male + p_female +
  plot_layout(ncol = 3, guides = "collect") &
  theme(
    legend.position = "top",
    legend.justification = "center",
    legend.text = element_text(size = 7, color = "black")
  )

p_ptdt_sex_panel
