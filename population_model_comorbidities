# -----------------------------------------------------------------------------
# 5. Prepare data for forest plots
# -----------------------------------------------------------------------------
prs_order <- c("EA", "CP", "NON_COG")

meta_logit_asd_FE2 <- meta_logit_asd_FE2 %>%
  mutate(
    group = case_when(
      grepl("^fa_", variable) ~ "Paternal",
      grepl("^mo_", variable) ~ "Maternal",
      variable %in% prs_order ~ "Proband",
      TRUE ~ NA_character_
    ),
    prs = case_when(
      group == "Paternal" ~ sub("^fa_", "", variable),
      group == "Maternal" ~ sub("^mo_", "", variable),
      group == "Proband"  ~ variable,
      TRUE ~ NA_character_
    )
  ) %>%
  filter(!is.na(group), prs %in% prs_order) %>%
  mutate(
    prs = factor(prs, levels = prs_order),
    group = factor(group, levels = c("Proband", "Paternal", "Maternal")),
    panel_title = case_when(
      phenotype == "dev_lang"    ~ "Developmental",
      phenotype == "mood_or_anx" ~ "Mood",
      phenotype == "attn_behav"  ~ "Behavior",
      phenotype == "schiz"       ~ "Schizophrenia",
      phenotype == "sleep_dx"    ~ "Sleep",
      TRUE ~ as.character(phenotype)
    )
  )

# Low-saturation colors for the three PGS source groups.
group_colors <- c(
  "Proband"  = "#B85C5C",
  "Paternal" = "#6487C0",
  "Maternal" = "#6AA27A"
)

# -----------------------------------------------------------------------------
# 6. Plot one phenotype-specific forest plot
# -----------------------------------------------------------------------------
plot_forest_one_pheno_ng <- function(dat, pheno) {
  d <- dat %>% filter(phenotype == pheno)
  if (nrow(d) == 0) return(NULL)

  d <- d %>%
    mutate(
      prs_y = factor(as.character(prs), levels = rev(prs_order)),
      group = factor(as.character(group), levels = c("Proband", "Paternal", "Maternal"))
    )

  pd <- position_dodge(width = 0.58)

  ggplot(
    d,
    aes(
      x = OR_FE,
      y = prs_y,
      xmin = CI_lower_FE,
      xmax = CI_upper_FE,
      color = group,
      group = group
    )
  ) +
    geom_vline(
      xintercept = 1,
      linetype = "dashed",
      linewidth = 0.35,
      color = "black"
    ) +
    geom_errorbarh(
      height = 0.16,
      position = pd,
      linewidth = 0.28
    ) +
    geom_point(
      size = 2.6,
      shape = 16,
      position = pd
    ) +
    geom_text(
      aes(label = sig),
      position = pd,
      vjust = -0.35,
      size = 2.4,
      fontface = "bold",
      show.legend = FALSE,
      color = "black"
    ) +
    scale_color_manual(
      values = group_colors,
      breaks = c("Proband", "Paternal", "Maternal"),
      name = NULL
    ) +
    scale_x_log10(
      breaks = c(0.8, 1.0, 1.2),
      labels = label_number(accuracy = 0.01)
    ) +
    scale_y_discrete(
      breaks = c("EA", "CP", "NON_COG"),
      labels = c(
        expression(PGS[EA]),
        expression(PGS[CP]),
        expression(PGS[NON_COG])
      )
    ) +
    labs(
      x = NULL,
      y = "Polygenic score",
      title = unique(d$panel_title)[1]
    ) +
    theme_classic(base_size = 11) +
    theme(
      axis.line = element_line(linewidth = 0.6, color = "black"),
      axis.ticks = element_line(linewidth = 0.5, color = "black"),
      axis.ticks.length = unit(2.0, "mm"),
      axis.text.y = element_text(size = 7, color = "black"),
      axis.text.x = element_text(size = 7, color = "black"),
      axis.title.x = element_text(size = 7, color = "black"),
      axis.title.y = element_text(size = 7, color = "black"),
      plot.title = element_text(size = 7, hjust = 0.5),
      legend.position = "right",
      legend.title = element_text(size = 7),
      legend.text = element_text(size = 7),
      legend.key.size = unit(0.7, "lines"),
      strip.text = element_text(size = 7, face = "bold", color = "black"),
      plot.margin = margin(8, 8, 8, 8)
    ) +
    guides(
      color = guide_legend(
        override.aes = list(
          shape = 16,
          size = 2.4
        )
      )
    )
}

# -----------------------------------------------------------------------------
# 7. Generate and combine forest plots
# -----------------------------------------------------------------------------
pheno_list <- c("dev_lang", "mood_or_anx", "attn_behav", "schiz", "sleep_dx")

plots <- lapply(pheno_list, function(p) plot_forest_one_pheno_ng(meta_logit_asd_FE2, p))
names(plots) <- pheno_list

plots <- lapply(plots, function(p) p + labs(x = NULL))

for (i in 2:length(plots)) {
  plots[[i]] <- plots[[i]] +
    labs(y = NULL) +
    theme(
      axis.text.y = element_blank(),
      axis.ticks.y = element_blank(),
      axis.line.y = element_blank()
    )
}

p_all <- wrap_plots(plots, nrow = 1) +
  plot_layout(guides = "collect") &
  theme(legend.position = "right")

p_all <- p_all +
  plot_annotation(
    caption = "Odds ratio",
    theme = theme(
      plot.caption = element_text(
        hjust = 0.5,
        size = 7,
        margin = margin(t = 8),
        color = "black"
      ),
      plot.margin = margin(5.5, 5.5, 16, 5.5)
    )
  )

p_all
