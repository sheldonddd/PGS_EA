# -----------------------------------------------------------------------------
# 5. Bubble plot for meta-analyzed PGS-phenotype associations
# -----------------------------------------------------------------------------
prs_order <- c("EA", "CP", "NON_COG")

make_prs_bubble_combined_ng <- function(meta_asd_FE, n_bonf = 18) {
  dat <- as.data.table(meta_asd_FE)

  # Classify PGS predictors by source: proband, paternal, or maternal.
  dat[, group := fifelse(
    grepl("^fa_", variable), "Paternal",
    fifelse(grepl("^mo_", variable), "Maternal", "Proband")
  )]

  # Remove parental prefixes to obtain the core PGS name.
  dat[, prs := variable]
  dat[group == "Paternal", prs := sub("^fa_", "", prs)]
  dat[group == "Maternal", prs := sub("^mo_", "", prs)]

  dat <- dat[prs %in% prs_order]

  if (nrow(dat) == 0) {
    warning("No PRS results found.")
    return(NULL)
  }

  # Apply Bonferroni correction separately within each PGS source group.
  dat[, p_adj := p.adjust(p_FE, method = "bonferroni", n = n_bonf), by = group]

  dat[, sig := fifelse(
    p_adj < 0.001, "***",
    fifelse(p_adj < 0.01, "**",
      fifelse(p_adj < 0.05, "*", "")
    )
  )]

  dat[, logP := -log10(p_adj)]

  # Replace infinite values for plotting if adjusted P values are zero.
  if (any(is.infinite(dat$logP))) {
    max_finite <- max(dat$logP[is.finite(dat$logP)], na.rm = TRUE)
    if (!is.finite(max_finite)) max_finite <- 25
    dat[is.infinite(logP), logP := max_finite + 1]
  }

  dat[, logP_plot := pmin(logP, 25)]

  dat[, prs := factor(prs, levels = prs_order)]
  dat[, phenotype := toupper(phenotype)]
  dat[, phenotype := factor(
    phenotype,
    levels = c("VABS", "DCDQ", "FSIQ", "RBSR", "SRS", "SCQ")
  )]
  dat[, group := factor(group, levels = c("Proband", "Paternal", "Maternal"))]

  max_abs_beta <- max(abs(dat$beta_FE), na.rm = TRUE)
  if (!is.finite(max_abs_beta) || max_abs_beta == 0) max_abs_beta <- 1

  p <- ggplot(
    dat,
    aes(
      x = prs,
      y = phenotype,
      size = logP_plot,
      fill = beta_FE
    )
  ) +
    geom_point(
      shape = 21,
      color = "gray25",
      stroke = 0.25,
      alpha = 0.95
    ) +
    geom_text(
      aes(label = sig),
      color = "black",
      size = 3.2,
      fontface = "bold",
      show.legend = FALSE
    ) +
    facet_wrap(~group, nrow = 1) +
    scale_x_discrete(
      breaks = c("EA", "CP", "NON_COG"),
      labels = c(
        expression(PGS[EA]),
        expression(PGS[CP]),
        expression(PGS[NON_COG])
      )
    ) +
    scale_fill_distiller(
      palette = "RdBu",
      direction = -1,
      limits = c(-max_abs_beta, max_abs_beta),
      name = "Effect size"
    ) +
    scale_size_continuous(
      range = c(4.5, 8.5),
      limits = c(0, 25),
      breaks = c(1, 5, 10, 25),
      name = expression(-log[10](P[adj]))
    ) +
    labs(
      x = NULL,
      y = NULL,
      title = NULL
    ) +
    theme_classic(base_size = 11) +
    theme(
      axis.line = element_line(linewidth = 0.6, color = "black"),
      axis.ticks = element_line(linewidth = 0.5, color = "black"),
      axis.ticks.length = unit(2.0, "mm"),
      axis.text.x = element_text(size = 7, color = "black", angle = 45, hjust = 1),
      axis.text.y = element_text(size = 7, color = "black"),
      axis.title.x = element_text(size = 7, color = "black"),
      axis.title.y = element_text(size = 7, color = "black"),
      strip.background = element_blank(),
      strip.text = element_text(size = 9, face = "bold", color = "black"),
      panel.spacing = unit(1.0, "lines"),
      legend.position = "right",
      legend.title = element_text(size = 9),
      legend.text = element_text(size = 8),
      legend.key.height = unit(0.9, "cm"),
      legend.key.width = unit(0.45, "cm"),
      plot.margin = margin(8, 10, 8, 8)
    ) +
    guides(
      size = guide_legend(
        override.aes = list(
          shape = 21,
          fill = "white",
          color = "gray25",
          stroke = 0.22,
          alpha = 1
        ),
        order = 2
      ),
      fill = guide_colorbar(
        frame.colour = "gray30",
        ticks.colour = "gray30",
        barheight = unit(3.2, "cm"),
        barwidth = unit(0.45, "cm"),
        order = 1
      )
    )

  return(p)
}

p_all_ng <- make_prs_bubble_combined_ng(meta_asd_FE, n_bonf = 18)
p_all_ng
