# Combine two data frames while removing duplicated columns from the right table.
cbind_drop_dup <- function(df_left, df_right) {
  duplicated_cols <- intersect(colnames(df_left), colnames(df_right))
  df_right_unique <- df_right[, setdiff(colnames(df_right), duplicated_cols), drop = FALSE]
  cbind(df_left, df_right_unique)
}

# Convert variables to numeric when possible.
to_num <- function(x) {
  if (is.numeric(x)) return(x)
  suppressWarnings(as.numeric(x))
}

# Standardize sex coding and set Female as the reference level when available.
standardize_sex <- function(dat, sex_var = "sex") {
  if (!(sex_var %in% names(dat))) {
    stop(paste0("Missing sex variable: ", sex_var))
  }

  dat[[sex_var]] <- as.factor(dat[[sex_var]])

  if (all(c("Female", "Male") %in% levels(dat[[sex_var]]))) {
    dat[[sex_var]] <- factor(dat[[sex_var]], levels = c("Female", "Male"))
  }

  dat
}

# Add PGS role labels.
add_role <- function(df) {
  df %>%
    mutate(
      role = case_when(
        grepl("^fa_", variable) ~ "Paternal",
        grepl("^mo_", variable) ~ "Maternal",
        TRUE ~ "Proband"
      ),
      prs_base = gsub("^fa_|^mo_", "", variable)
    )
}


