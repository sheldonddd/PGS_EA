plot_trio_logistic_forest <- function(meta_logistic_FE2,
                                      prs_order = c("EA", "CP", "NON_COG")) {

  data_prepared <- meta_logistic_FE2 %>%
    mutate(
      prs = factor(PRS, levels = prs_order),
      effect_type = case_when(
        role == "Proband"  ~ "Proband",
        role == "Paternal" ~ "Paternal",
        role == "Maternal" ~ "Maternal"
      ),
      effect_type = factor(
        effect_type,
        levels = c("Proband", "Paternal", "Maternal")
      ),
      phenotype_label = case_when(
        phenotype == "dev_lang"    ~ "Developmental",
        phenotype == "mood_or_anx" ~ "Mood",
        phenotype == "attn_behav"  ~ "Behavior",
        phenotype == "schiz"       ~ "Schizophrenia",
        phenotype == "sleep_dx"    ~ "Sleep",
        TRUE ~ as.character(phenotype)
      ),
      phenotype_label = factor(
        phenotype_label,
        levels = c("Developmental", "Mood", "Behavior", "Schizophrenia", "Sleep")
      )
    )

  prs_labels <- c(
    EA = "PGS[EA]",
    CP = "PGS[CP]",
    NON_COG = "PGS[NON_COG]"
  )

  effect_colors <- c(
    "Proband"  = "#B85C5C",
    "Paternal" = "#6487C0",
    "Maternal" = "#6AA27A"
  )

  create_single_phenotype_plot <- function(data, pheno,
                                           show_y_axis = FALSE,
                                           show_legend = FALSE) {

    plot_data <- data %>%
      filter(phenotype_label == pheno) %>%
      arrange(prs, effect_type) %>%
      mutate(
        prs = factor(as.character(prs), levels = rev(prs_order)),
        effect_type = factor(
          as.character(effect_type),
          levels = c("Proband", "Paternal", "Maternal")
        )
      )

    if (nrow(plot_data) == 0) return(NULL)

    pd <- position_dodge(width = 0.58)

    x_range <- range(c(plot_data$CI_lower_FE, plot_data$CI_upper_FE), na.rm = TRUE)
    x_padding <- diff(x_range) * 0.15

    ggplot(
      plot_data,
      aes(
        x = OR_FE,
        y = prs,
        xmin = CI_lower_FE,
        xmax = CI_upper_FE,
        color = effect_type,
        group = effect_type
      )
    ) +
      geom_vline(
        xintercept = 1,
        linetype = "dashed",
        linewidth = 0.3,
        color = "#999999"
      ) +
      geom_errorbarh(
        height = 0.14,
        position = pd,
        linewidth = 0.4,
        alpha = 0.9
      ) +
      geom_point(
        size = 1.8,
        shape = 16,
        position = pd
      ) +
      geom_text(
        aes(label = sig),
        position = pd,
        vjust = -0.35,
        size = 2.2,
        fontface = "bold",
        color = "black",
        show.legend = FALSE
      ) +
      scale_color_manual(
        values = effect_colors,
        breaks = c("Proband", "Paternal", "Maternal"),
        name = NULL,
        guide = if (show_legend) "legend" else "none"
      ) +
      scale_y_discrete(
        labels = function(x) parse(text = prs_labels[x])
      ) +
      scale_x_log10(
        limits = c(
          max(0.1, x_range[1] - x_padding),
          min(10,  x_range[2] + x_padding)
        ),
        breaks = function(limits) {
          if (limits[2] / limits[1] > 100) {
            c(0.1, 0.5, 1, 2, 5, 10)
          } else if (limits[2] / limits[1] > 20) {
            c(0.5, 1, 2, 5)
          } else if (limits[2] / limits[1] > 10) {
            c(0.5, 1, 2, 3)
          } else {
            pretty(limits, n = 4)
          }
        },
        expand = expansion(mult = c(0.05, 0.05))
      ) +
      labs(
        x = NULL,
        y = if (show_y_axis) "Polygenic score" else NULL,
        title = pheno
      ) +
      theme_classic(base_size = 7) +
      theme(
        axis.line.x = element_line(linewidth = 0.35, color = "black"),
        axis.line.y = if (show_y_axis) {
          element_line(linewidth = 0.35, color = "black")
        } else {
          element_blank()
        },
        axis.ticks.x = element_line(linewidth = 0.3, color = "black"),
        axis.ticks.y = if (show_y_axis) {
          element_line(linewidth = 0.3, color = "black")
        } else {
          element_blank()
        },
        axis.ticks.length = unit(1.5, "mm"),
        axis.text.x = element_text(size = 7, color = "black"),
        axis.text.y = if (show_y_axis) {
          element_text(size = 7, color = "black")
        } else {
          element_blank()
        },
        axis.title.x = element_text(size = 7, color = "black"),
        axis.title.y = if (show_y_axis) {
          element_text(size = 7, color = "black")
        } else {
          element_blank()
        },
        plot.title = element_text(
          size = 7,
          face = "bold",
          hjust = 0.5,
          color = "black"
        ),
        legend.position = if (show_legend) "right" else "none",
        legend.title = element_text(size = 7),
        legend.text = element_text(size = 7),
        legend.key.size = unit(0.7, "lines"),
        plot.margin = margin(6, 6, 6, 6)
      ) +
      guides(
        color = guide_legend(
          override.aes = list(shape = 16, size = 2.2)
        )
      )
  }

  phenotypes <- levels(data_prepared$phenotype_label)

  plot_list <- vector("list", length(phenotypes))

  for (i in seq_along(phenotypes)) {
    plot_list[[i]] <- create_single_phenotype_plot(
      data_prepared,
      phenotypes[i],
      show_y_axis = (i == 1),
      show_legend = (i == length(phenotypes))
    )
  }

  combined_plots <- wrap_plots(
    plot_list,
    nrow = 1,
    widths = c(1.2, 1, 1, 1, 1.2)
  )

  combined_plots +
    plot_annotation(
      caption = "Odds Ratio",
      theme = theme(
        plot.caption = element_text(
          size = 7,
          hjust = 0.5,
          margin = margin(t = 8, b = 4),
          color = "black"
        ),
        plot.margin = margin(5.5, 5.5, 14, 5.5)
      )
    )
}

