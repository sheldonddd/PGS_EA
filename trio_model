plot_trio_linear_forest <- function(meta_linear_FE, prs_set = c("EA", "CP", "NON_COG")) {

  group_data <- meta_linear_FE %>%
    filter(PRS %in% prs_set) %>%
    mutate(
      effect_type = case_when(
        variable == PRS ~ "Direct (Proband)",
        grepl("^fa_", variable) ~ "Indirect (Paternal)",
        grepl("^mo_", variable) ~ "Indirect (Maternal)",
        TRUE ~ NA_character_
      ),
      significance = case_when(
        p_FE < 0.001 / 18 ~ "***",
        p_FE < 0.01  / 18 ~ "**",
        p_FE < 0.05  / 18 ~ "*",
        TRUE ~ ""
      ),
      PRS = factor(as.character(PRS), levels = prs_set),
      phenotype = factor(
        toupper(as.character(phenotype)),
        levels = rev(c("SCQ", "SRS", "RBSR", "FSIQ", "DCDQ", "VABS"))
      ),
      ci_lower = beta_FE - 1.96 * se_FE,
      ci_upper = beta_FE + 1.96 * se_FE
    ) %>%
    filter(
      !is.na(effect_type),
      !is.na(beta_FE),
      !is.na(se_FE),
      !is.na(phenotype),
      !is.na(PRS)
    )

  prs_label_expr <- function(prs_name) {
    switch(
      as.character(prs_name),
      "EA" = expression(PGS[EA]),
      "CP" = expression(PGS[CP]),
      "NON_COG" = expression(PGS[NON_COG])
    )
  }

  create_forest_one_panel <- function(data, prs_name, show_y = FALSE) {

    d <- data %>% filter(PRS == prs_name)
    pd <- position_dodge(width = 0.55)

    p <- ggplot(
      d,
      aes(
        x = beta_FE,
        y = phenotype,
        colour = effect_type,
        group = effect_type
      )
    ) +
      geom_vline(
        xintercept = 0,
        linetype = "dashed",
        linewidth = 0.3,
        color = "grey40"
      ) +
      geom_errorbarh(
        aes(xmin = ci_lower, xmax = ci_upper),
        height = 0.12,
        linewidth = 0.5,
        position = pd
      ) +
      geom_point(
        size = 1.8,
        shape = 16,
        position = pd
      ) +
      geom_text(
        aes(label = significance),
        position = pd,
        vjust = -0.35,
        hjust = 0.5,
        color = "black",
        size = 7 / .pt,
        fontface = "bold",
        show.legend = FALSE,
        na.rm = TRUE
      ) +
      scale_color_manual(
        values = c(
          "Direct (Proband)" = "#E41A1C",
          "Indirect (Paternal)" = "#377EB8",
          "Indirect (Maternal)" = "#4DAF4A"
        ),
        name = NULL,
        breaks = c(
          "Direct (Proband)",
          "Indirect (Paternal)",
          "Indirect (Maternal)"
        )
      ) +
      labs(
        title = NULL,
        x = prs_label_expr(prs_name),
        y = if (show_y) "Phenotype" else NULL
      ) +
      coord_cartesian(clip = "off") +
      theme_classic(base_size = 7) +
      theme(
        axis.line = element_line(linewidth = 0.4, color = "black"),
        axis.ticks = element_line(linewidth = 0.35, color = "black"),
        axis.ticks.length = unit(1.5, "mm"),
        axis.text.x = element_text(size = 7, color = "black"),
        axis.text.y = element_text(size = 7, color = "black"),
        axis.title.x = element_text(size = 7, color = "black", margin = margin(t = 4)),
        axis.title.y = element_text(size = 7, color = "black"),
        plot.title = element_blank(),
        legend.position = "top",
        legend.direction = "horizontal",
        legend.text = element_text(size = 7, color = "black"),
        legend.title = element_text(size = 7, color = "black"),
        legend.key.size = unit(0.7, "lines"),
        plot.margin = margin(5.5, 12, 5.5, 5.5)
      ) +
      guides(
        colour = guide_legend(
          override.aes = list(shape = 16, size = 2),
          nrow = 1
        )
      )

    if (!show_y) {
      p <- p +
        theme(
          axis.text.y = element_blank(),
          axis.ticks.y = element_blank(),
          axis.line.y = element_blank()
        )
    }

    p
  }

  p1 <- create_forest_one_panel(group_data, "EA", show_y = TRUE)
  p2 <- create_forest_one_panel(group_data, "CP", show_y = FALSE)
  p3 <- create_forest_one_panel(group_data, "NON_COG", show_y = FALSE)

  (p1 + p2 + p3) +
    plot_layout(guides = "collect") &
    theme(legend.position = "top")
}

