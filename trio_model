# -----------------------------------------------------------------------------
# 5. Multivariable linear models for quantitative phenotypes
# -----------------------------------------------------------------------------

run_multivariate_linear <- function(data, y_list, x_interest, pc_cols = paste0("X", 1:10)) {

  dat <- as.data.table(data)
  out <- list()

  # Convert potentially numeric columns imported from Excel as characters.
  maybe_num <- unique(c(y_list, paste0(y_list, "_age"), x_interest, pc_cols))
  for (v in intersect(maybe_num, names(dat))) {
    if (v != "sex") dat[[v]] <- to_num(dat[[v]])
  }

  # Z-standardize ancestry PCs.
  for (pc in pc_cols) {
    if (pc %in% names(dat) && is.numeric(dat[[pc]])) {
      dat[[paste0(pc, "_z")]] <- as.numeric(scale(dat[[pc]]))
    }
  }

  # Z-standardize PGS predictors.
  x_interest_z <- character(0)

  for (x in x_interest) {
    if (!(x %in% names(dat))) {
      warning(paste("Variable not found, skipped:", x))
      next
    }

    if (is.numeric(dat[[x]])) {
      x_z <- paste0(x, "_z")
      dat[[x_z]] <- as.numeric(scale(dat[[x]]))
      x_interest_z <- c(x_interest_z, x_z)
    } else {
      warning(paste("Non-numeric variable cannot be standardized, skipped:", x))
    }
  }

  if (length(x_interest_z) == 0) {
    stop("No valid numeric variables in x_interest.")
  }

  # Fit one multivariable model per phenotype.
  for (y in y_list) {

    if (!(y %in% names(dat))) next
    if (!is.numeric(dat[[y]])) next

    y_z <- paste0(y, "_z")
    dat[[y_z]] <- as.numeric(scale(dat[[y]]))

    age_var <- paste0(y, "_age")

    x_use <- c(
      x_interest_z,
      "sex",
      if (age_var %in% names(dat)) age_var else NULL,
      intersect(paste0(pc_cols, "_z"), names(dat))
    )

    form <- as.formula(paste0(y_z, " ~ ", paste(x_use, collapse = " + ")))

    fit <- lm(form, data = dat)
    sm  <- summary(fit)
    n   <- nobs(fit)

    coef_tab <- as.data.frame(sm$coefficients)
    coef_tab$variable <- rownames(coef_tab)

    selected <- coef_tab[coef_tab$variable %in% x_interest_z, , drop = FALSE]
    if (nrow(selected) == 0) next

    selected$variable  <- sub("_z$", "", selected$variable)
    selected$phenotype <- y
    selected$R2        <- sm$r.squared
    selected$n         <- n

    out[[y]] <- selected
  }

  res <- do.call(rbind, out)
  rownames(res) <- NULL
  res
}

run_trio_linear_all_prs <- function(dat_asd, y_list, prs_set, pc_cols = paste0("X", 1:10)) {
  all_res <- lapply(prs_set, function(prs) {
    x_interest <- c(prs, paste0("fa_", prs), paste0("mo_", prs))
    tmp <- run_multivariate_linear(dat_asd, y_list, x_interest, pc_cols = pc_cols)
    tmp$PRS <- prs
    tmp
  })

  do.call(rbind, all_res)
}


# -----------------------------------------------------------------------------
# 6. Multivariable logistic models for binary phenotypes
# -----------------------------------------------------------------------------

run_multivariate_logistic <- function(data, y_list, x_interest,
                                      age_col = "med_age",
                                      pc_cols = paste0("X", 1:10)) {

  dat <- as.data.table(data)
  out <- list()

  if (!("sex" %in% names(dat))) stop("Missing sex variable.")
  if (!(age_col %in% names(dat))) stop(paste0("Missing age variable: ", age_col))

  dat <- standardize_sex(dat)

  # Convert potentially numeric columns imported from Excel as characters.
  maybe_num <- unique(c(y_list, x_interest, age_col, pc_cols))
  for (v in intersect(maybe_num, names(dat))) {
    if (v != "sex") dat[[v]] <- to_num(dat[[v]])
  }

  # Z-standardize ancestry PCs.
  for (pc in pc_cols) {
    if (pc %in% names(dat) && is.numeric(dat[[pc]])) {
      dat[[paste0(pc, "_z")]] <- as.numeric(scale(dat[[pc]]))
    }
  }

  # Z-standardize PGS predictors.
  x_interest_z <- character(0)

  for (x in x_interest) {
    if (!(x %in% names(dat))) {
      warning(paste("Variable not found, skipped:", x))
      next
    }

    if (is.numeric(dat[[x]])) {
      x_z <- paste0(x, "_z")
      dat[[x_z]] <- as.numeric(scale(dat[[x]]))
      x_interest_z <- c(x_interest_z, x_z)
    } else {
      warning(paste("Non-numeric variable cannot be standardized, skipped:", x))
    }
  }

  if (length(x_interest_z) == 0) {
    stop("No valid numeric variables in x_interest.")
  }

  # Fit one multivariable logistic model per binary phenotype.
  for (y in y_list) {

    if (!(y %in% names(dat))) {
      warning(paste("Phenotype not found, skipped:", y))
      next
    }

    dat[[y]] <- as.numeric(dat[[y]])

    x_use <- c(
      x_interest_z,
      "sex",
      age_col,
      intersect(paste0(pc_cols, "_z"), names(dat))
    )

    form <- as.formula(paste0(y, " ~ ", paste(x_use, collapse = " + ")))

    fit <- glm(form, data = dat, family = binomial)
    sm  <- summary(fit)
    n   <- nobs(fit)

    coef_tab <- as.data.frame(sm$coefficients)
    coef_tab$variable <- rownames(coef_tab)

    selected <- coef_tab[coef_tab$variable %in% x_interest_z, , drop = FALSE]
    if (nrow(selected) == 0) next

    # Odds ratios and 95% confidence intervals.
    selected$OR       <- exp(selected$Estimate)
    selected$CI_lower <- exp(selected$Estimate - 1.96 * selected$`Std. Error`)
    selected$CI_upper <- exp(selected$Estimate + 1.96 * selected$`Std. Error`)

    # McFadden pseudo-R2.
    null_fit <- glm(as.formula(paste0(y, " ~ 1")), data = dat, family = binomial)
    selected$R2 <- 1 - as.numeric(logLik(fit) / logLik(null_fit))

    selected$variable  <- sub("_z$", "", selected$variable)
    selected$phenotype <- y
    selected$n         <- n

    out[[y]] <- selected
  }

  res <- do.call(rbind, out)
  rownames(res) <- NULL
  res
}

run_trio_logistic_all_prs <- function(dat_asd, y_list, prs_set,
                                      age_col = "med_age",
                                      pc_cols = paste0("X", 1:10)) {
  all_res <- lapply(prs_set, function(prs) {
    x_interest <- c(prs, paste0("fa_", prs), paste0("mo_", prs))
    tmp <- run_multivariate_logistic(
      dat_asd,
      y_list,
      x_interest,
      age_col = age_col,
      pc_cols = pc_cols
    )
    tmp$PRS <- prs
    tmp
  })

  do.call(rbind, all_res)
}


# -----------------------------------------------------------------------------
# 7. Fixed-effect meta-analysis functions
# -----------------------------------------------------------------------------

meta_two_studies_FE_linear <- function(res_D, res_R,
                                       key_cols = c("phenotype", "PRS", "variable"),
                                       beta_col = "Estimate",
                                       se_col   = "Std. Error") {

  D <- res_D %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, R2) %>%
    rename(
      beta_D = all_of(beta_col),
      se_D   = all_of(se_col),
      n_D    = n,
      R2_D   = R2
    )

  R <- res_R %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n, R2) %>%
    rename(
      beta_R = all_of(beta_col),
      se_R   = all_of(se_col),
      n_R    = n,
      R2_R   = R2
    )

  M <- inner_join(D, R, by = key_cols) %>%
    filter(
      is.finite(beta_D), is.finite(beta_R),
      is.finite(se_D),   is.finite(se_R),
      se_D > 0, se_R > 0
    )

  if (nrow(M) == 0) return(M)

  wD <- 1 / (M$se_D^2)
  wR <- 1 / (M$se_R^2)
  w  <- wD + wR

  beta_FE <- (wD * M$beta_D + wR * M$beta_R) / w
  se_FE   <- sqrt(1 / w)
  z_FE    <- beta_FE / se_FE
  p_FE    <- 2 * pnorm(-abs(z_FE))

  M %>%
    mutate(
      beta_FE = beta_FE,
      se_FE   = se_FE,
      z_FE    = z_FE,
      p_FE    = p_FE
    )
}

meta_two_studies_FE_logistic <- function(res_D, res_R,
                                         key_cols = c("phenotype", "PRS", "role"),
                                         beta_col = "Estimate",
                                         se_col   = "Std. Error") {

  D <- res_D %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n) %>%
    rename(
      beta_D = all_of(beta_col),
      se_D   = all_of(se_col),
      n_D    = n
    )

  R <- res_R %>%
    select(all_of(key_cols), all_of(beta_col), all_of(se_col), n) %>%
    rename(
      beta_R = all_of(beta_col),
      se_R   = all_of(se_col),
      n_R    = n
    )

  M <- inner_join(D, R, by = key_cols) %>%
    filter(
      is.finite(beta_D), is.finite(beta_R),
      is.finite(se_D),   is.finite(se_R),
      se_D > 0, se_R > 0
    )

  if (nrow(M) == 0) return(M)

  wD <- 1 / (M$se_D^2)
  wR <- 1 / (M$se_R^2)
  w  <- wD + wR

  beta_FE <- (wD * M$beta_D + wR * M$beta_R) / w
  se_FE   <- sqrt(1 / w)
  z_FE    <- beta_FE / se_FE
  p_FE    <- 2 * pnorm(-abs(z_FE))

  M %>%
    mutate(
      beta_FE     = beta_FE,
      se_FE       = se_FE,
      z_FE        = z_FE,
      p_FE        = p_FE,
      OR_FE       = exp(beta_FE),
      CI_lower_FE = exp(beta_FE - 1.96 * se_FE),
      CI_upper_FE = exp(beta_FE + 1.96 * se_FE)
    )
}


